# Required API Keys
PEXELS_API_KEY=your_pexels_api_key_here

# Persian Language Support (Optional)
# Get your free OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Default Language Configuration
# Options: en (English), fa (Persian/Farsi)
DEFAULT_LANGUAGE=en

# System Configuration
LOG_LEVEL=info
WHISPER_VERBOSE=false
PORT=3123

# Advanced Configuration
# For Persian language support, use multilingual models
WHISPER_MODEL=medium
KOKORO_MODEL_PRECISION=fp32

# Performance Tuning (for limited resources)
# CONCURRENCY=1
# VIDEO_CACHE_SIZE_IN_BYTES=2097152000

# Docker Configuration (only when running in Docker)
# DOCKER=true
# DATA_DIR_PATH=/app/data

# Development Mode
# DEV=false